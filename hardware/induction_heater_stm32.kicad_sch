$kicad_sch
$version 1
$encoding utf-8
$format 1


(lib
  (symbol (name MCU_ST_STM32F1:STM32F103C8Tx)
    (property "Device" "STM32F103C8Tx"))

  (power (name +3V3))
  (power (name GND))

  (capacitor (name C1) (value 100nF))
  (capacitor (name C2) (value 100nF))
  (resistor (name R1) (value 10k))
  (button (name BTN_RESET) (value Reset))

  (header (name SWD_HEADER)
    (pin (name PA13) (type GPIO))
    (pin (name PA14) (type GPIO))
    (pin (name NRST) (type GPIO))
    (pin (name +3V3) (type POWER))
    (pin (name GND) (type POWER)))

  (header (name UART_HEADER)
    (pin (name PA9) (type GPIO))
    (pin (name PA10) (type GPIO))
    (pin (name GND) (type POWER)))

  (crystal (name XTAL_HSE)
    (value 8MHz)
    (load_capacitor (name CLOAD1))
    (load_capacitor (name CLOAD2))))
)  
$end